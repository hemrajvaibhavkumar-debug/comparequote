generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Executive {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  designation String?
  created_at  DateTime     @default(now())
  comparisons Comparison[]
}

model Plant {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  location    String?
  created_at  DateTime     @default(now())
  comparisons Comparison[]
}

model Comparison {
  id           Int        @id @default(autoincrement())
  doc_no       String     @unique
  created_at   DateTime   @default(now())
  data         Json
  executive    Executive? @relation(fields: [executive_id], references: [id])
  executive_id Int?
  plant        Plant?     @relation(fields: [plant_id], references: [id])
  plant_id     Int?

  @@index([created_at(sort: Desc)])
}

model User {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String
}

model CompanySettings {
  id        Int      @id @default(1)
  name      String   @default("My Company")
  logo      String?  // Base64 or URL
  cin       String?
  gstin     String?
  pan       String?
  address   String?
  email     String?
  phone     String?
  website   String?
  factory_address String?
  regd_office String?
}

model TermsTemplate {
  id      Int    @id @default(autoincrement())
  name    String @unique
  tax     String?
  packing String?
  payment String?
  freight String?
  delivery String?
  contact_no String?
  notes   String?
}

model PurchaseOrder {
  id              Int      @id @default(autoincrement())
  po_no           String   @unique
  date            DateTime @default(now())
  vendor_name     String
  vendor_details  Json?    // Address, GSTIN, Mail, Ph
  items           Json     // List of items
  terms           Json?    // Snapshot of terms used
  total_amount    Float    @default(0)
  created_at      DateTime @default(now())
}
