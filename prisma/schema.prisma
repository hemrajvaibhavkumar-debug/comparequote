generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Executive {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  designation String?
  created_at  DateTime     @default(now())
  comparisons Comparison[]
}

model Plant {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  location    String?
  created_at  DateTime     @default(now())
  comparisons Comparison[]
}

model Comparison {
  id                Int        @id @default(autoincrement())
  doc_no            String     @unique
  created_at        DateTime   @default(now())
  data              Json
  internal_comments Json?      // Array of objects: { text, date, author }
  executive         Executive? @relation(fields: [executive_id], references: [id])
  executive_id      Int?
  plant             Plant?     @relation(fields: [plant_id], references: [id])
  plant_id          Int?

  @@index([created_at(sort: Desc)])
}

model User {
  id          Int      @id @default(autoincrement())
  username    String   @unique
  password    String
  role        String   @default("USER") // SUPERADMIN, PURCHASE_HEAD, USER
  permissions Json? // Array of strings
  created_at  DateTime @default(now())
}

model SystemRole {
  id   Int    @id @default(autoincrement())
  name String @unique
}

model CompanySettings {
  id              Int     @id @default(1)
  name            String  @default("My Company")
  logo            String? // Base64 or URL
  cin             String?
  gstin           String?
  pan             String?
  address         String?
  email           String?
  phone           String?
  website         String?
  factory_address String?
  regd_office     String?
}

model TermsTemplate {
  id         Int     @id @default(autoincrement())
  name       String  @unique
  tax        String?
  packing    String?
  payment    String?
  freight    String?
  delivery   String?
  contact_no String?
  notes      String?
}

model PurchaseOrder {
  id                Int       @id @default(autoincrement())
  po_no             String    @unique
  date              DateTime  @default(now())
  quote_date        String?
  quote_ref_type    String?
  quote_doc_no      String?
  vendor_name       String
  version           String? // hemraj_ind, hemraj_rice, radhashyam
  vendor_details    Json? // Address, GSTIN, Mail, Ph
  items             Json // List of items
  terms             Json? // Snapshot of terms used
  total_amount      Float     @default(0)
  created_by_name   String?
  status            String    @default("PENDING") // PENDING, APPROVED, REJECTED
  rejection_remarks String?
  approved_by       String?
  approved_at       DateTime?
  pdf_base64        String?
  internal_comments Json?      // Array of objects: { text, date, author }
  created_at        DateTime  @default(now())
}

model VendorMaster {
  id        Int     @id @default(autoincrement())
  name      String
  address   String? @map("_address")
  state     String?
  gstin     String?
  mobile_no String? @map("mobile_no")

  @@map("vendor")
}

model Indent {
  id              Int       @id @default(autoincrement())
  indent_no       String    @unique
  date            DateTime  @default(now())
  department      String?
  items           Json      // Array of objects: { itemName, qty, uom, applicationArea, orderPlacedBy, orderPassedBy }
  total_items     Int       @default(0)
  status          String    @default("PENDING") // PENDING, APPROVED, REJECTED
  created_by_name String?
  rejection_remarks String?
  approved_by     String?
  approved_at     DateTime?
  internal_comments Json?     // Array of objects: { text, date, author }
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
}
