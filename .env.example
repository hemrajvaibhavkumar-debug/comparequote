# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# DATABASE_URL: Neon PostgreSQL connection string.
DATABASE_URL="postgres://user:password@endpoint.neon.tech/neondb"

# VITE_GOOGLE_CLIENT_ID: Used for Google Workspace Authentication.
VITE_GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID"

# GEMINI_API_KEY: Used for parsing vendor/quotes data.
GEMINI_API_KEY="your_gemini_api_key"

# GROQ_API_KEY: Used for fast bulk item extraction in PO Maker.
GROQ_API_KEY="your_groq_api_key"

# OPENROUTER_API_KEY: Used for Gemini 2.0 Flash via OpenRouter.
OPENROUTER_API_KEY="your_openrouter_api_key"

# n8n Webhook URL for sending PO emails
N8N_WEBHOOK_URL="https://purchasetesting01.app.n8n.cloud/webhook-test/a0fff28a-0958-4b81-a410-00b72fb8ae41"

# n8n Webhook URL for syncing Approved Indents
INDENT_WEBHOOK_URL="https://purchasetesting01.app.n8n.cloud/webhook-test/indent-webhook"

# n8n Webhook URL for sending quotation inquiries
INQUIRY_WEBHOOK_URL="https://purchasetesting01.app.n8n.cloud/webhook-test/inquiry-webhook"

